{
  "name": "road-rescue-system-apk",
  "version": "1.0.0",
  "description": "Road Rescue System - Android APK build",
  "main": "index.js",
  "scripts": {
    "build": "echo build done",
    "start": "node server.js",
    "test:appium": "wdio run ./appium-tests/config/wdio.conf.js",
    "test:web": "mocha ./globalHooks.js ./selenium-tests/specs/web-e2e.spec.js --timeout 120000 --exit",
    "test:backend": "mocha ./backend-tests/backend-unit.spec.js ./backend-tests/backend-validation.spec.js ./backend-tests/backend-load.spec.js --timeout 180000 --exit",
    "test:load": "node ./backend-tests/load-test.js",
    "test:all": "npm run test:web && npm run test:backend"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.1",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@wdio/appium-service": "^9.29.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "appium": "^3.5.2",
    "appium-uiautomator2-driver": "^8.1.0",
    "autocannon": "^8.0.0",
    "chai": "^4.3.10",
    "chromedriver": "^132.0.0",
    "exceljs": "^4.4.0",
    "mocha": "^11.7.6",
    "selenium-webdriver": "^4.45.0",
    "supertest": "^7.2.2"
  }
}